{
  "name": "clemmy",
  "version": "1.7.3",
  "description": "Lightweight background agent system — proactive, customizable, runs out of the box",
  "license": "MIT",
  "homepage": "https://github.com/Natebreynolds/clemmy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Natebreynolds/clemmy.git"
  },
  "keywords": [
    "agent",
    "ai",
    "assistant",
    "openai",
    "mcp",
    "background",
    "autonomous",
    "cli"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "clementine": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "apps/mobile-web/dist",
    "apps/console-web/dist",
    "vendor/uv",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "clean:dist": "node scripts/clean-dist.mjs",
    "prebuild": "npm run clean:dist",
    "build": "tsc --outDir dist",
    "build:mobile-web": "npm --prefix apps/mobile-web run build",
    "build:console-web": "npm --prefix apps/console-web run build",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts' 'apps/**/*.test.ts'",
    "test:release-assets": "node --test apps/desktop/scripts/vendor-recall-native.test.mjs scripts/merge-mac-update-feeds.test.mjs scripts/refresh-notarized-dmg-metadata.test.mjs scripts/release-workflow.test.mjs scripts/vendor-whispercpp-desktop.test.mjs scripts/verify-desktop-release-assets.test.mjs",
    "bench:gates": "tsx scripts/harness-gate-benchmark.ts",
    "eval:passk": "tsx scripts/eval-passk.ts",
    "eval:memory": "tsx scripts/eval-memory-reliability.ts",
    "audit:memory": "tsx scripts/audit-memory-readiness.ts",
    "rehearse:memory": "tsx scripts/rehearse-memory-migration.ts",
    "eval:spans": "tsx scripts/eval-spans.ts",
    "eval:promote": "tsx scripts/eval-promote.ts",
    "measure:code-mode": "tsx scripts/measure-code-mode-opportunity.ts",
    "probe:judge": "tsx scripts/probe-boundary-judge.ts",
    "probe:judge:live": "tsx scripts/probe-judge-live.ts",
    "stress:memory": "tsx scripts/memory-roundtrip-stress.ts",
    "smoke:fusion-readiness": "tsx scripts/smoke-fusion-readiness.ts",
    "smoke:objective-workflow": "tsx scripts/smoke-objective-workflow.mts",
    "test:smoke": "node scripts/smoke-fresh-install.mjs && node scripts/smoke-fresh-install-e2e.mjs",
    "test:smoke:gate": "node scripts/smoke-fresh-install.mjs",
    "smoke:codex-native-compaction": "node scripts/smoke-codex-native-compaction.mjs",
    "smoke:report-back": "tsx scripts/smoke-unified-report-back.ts",
    "vendor:uv": "node scripts/vendor-uv.mjs",
    "vendor:whisper": "node scripts/vendor-whispercpp.mjs",
    "vendor:whisper:desktop": "node scripts/vendor-whispercpp-desktop.mjs",
    "smoke:markitdown": "node scripts/smoke-markitdown.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run build && npm run build:mobile-web && npm run build:console-web && npm run vendor:uv",
    "pack:local": "npm pack",
    "chat": "tsx src/index.ts chat",
    "daemon": "tsx src/index.ts daemon",
    "daemon:start": "tsx src/index.ts daemon start",
    "daemon:stop": "tsx src/index.ts daemon stop",
    "daemon:status": "tsx src/index.ts daemon status",
    "daemon:logs": "tsx src/index.ts daemon logs",
    "service": "tsx src/index.ts service",
    "webhook": "tsx src/index.ts webhook",
    "discord": "tsx src/index.ts discord",
    "setup": "tsx src/index.ts setup",
    "doctor": "tsx src/setup/doctor.ts",
    "init-home": "tsx src/index.ts init-home",
    "auth": "tsx src/index.ts auth",
    "mcp": "tsx src/tools/mcp-server.ts",
    "plugin": "tsx src/index.ts plugin",
    "probe:code-mode": "tsx scripts/probe-code-mode.ts",
    "smoke:all": "bash scripts/smoke-all.sh",
    "eval:jobs": "tsx scripts/eval-jobs.ts",
    "job:capture": "tsx scripts/capture-job-fixture.ts",
    "measure:judge-calibration": "tsx scripts/measure-judge-calibration.ts",
    "proof": "tsx scripts/proof/run-proof.ts",
    "proof:claude": "tsx scripts/proof/run-proof.ts --brain claude",
    "proof:codex": "tsx scripts/proof/run-proof.ts --brain codex",
    "proof:glm": "tsx scripts/proof/run-proof.ts --brain glm",
    "proof:selftest": "tsx --test 'scripts/proof/*.test.ts'"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.82",
    "@anthropic-ai/claude-agent-sdk": "^0.3.199",
    "@composio/core": "^0.10.0",
    "@inquirer/prompts": "^8.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.12.0",
    "@openai/agents-core": "^0.12.0",
    "@openai/agents-extensions": "^0.12.0",
    "@openai/agents-openai": "^0.12.0",
    "@openai/agents-realtime": "^0.12.0",
    "@slack/bolt": "^4.7.3",
    "3d-force-graph": "^1.80.0",
    "ai": "^6.0.199",
    "better-sqlite3": "^12.11.1",
    "cytoscape": "^3.33.3",
    "discord.js": "^14.26.4",
    "express": "^4.22.2",
    "gray-matter": "^4.0.3",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "hono": "^4.12.27",
    "ip-address": "^10.2.0",
    "qs": "^6.15.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.12.0",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "js-yaml": "^5.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
